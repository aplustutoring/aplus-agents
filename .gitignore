.claude/
.DS_Store

# Environment variables - never commit secrets
.env
.env.local
*.env

# Python build artifacts
__pycache__/
*.pyc

# Runtime usage logs (machine state, grow over time). Scripts live in subdirs
# (b2b/ b2c/ shared/) after the restructure, so match usage logs at any depth.
scripts/**/*-usage.log

# Bundle outputs (too large for git; produced by weekly content engine)
aplus-content/

# State lock sidecars (transient — fcntl.flock anchors)
state/*.lock

# Embedding cache (rebuilt cheaply each CI run; would bloat repo)
state/blog-embeddings.json

# Spotlight orchestrator local run history — accumulates per-machine
state/spotlight-runs.json

# Case study Phase 1 — local-only files
scripts/**/*.bak

# Orphaned state dir from the pre-fix path bug (real state lives at repo-root state/)
scripts/state/

# Spotlight reel — standalone prototype scratch (superseded by scripts/b2c/reel/)
/spotlight-reel/
/spotlight-reel-*.mp4

# Textstory — standalone prototype scratch (superseded by scripts/b2c/textstory/)
/textstory/
/textstory-*.mp4
