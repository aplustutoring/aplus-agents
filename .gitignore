.claude/
.DS_Store

# Environment variables - never commit secrets
.env
.env.local
*.env

# Python build artifacts
__pycache__/
*.pyc

# Runtime usage logs (machine state, grow over time). Scripts live under
# marketing/scripts/<b2b|b2c|shared|watcher>/, so match usage logs at any depth.
marketing/scripts/**/*-usage.log

# Bundle outputs (too large for git; produced by the content/spotlight engines).
# Unanchored so it matches wherever a bundle dir lands (marketing/aplus-content/
# from REPO_ROOT-based scripts, or a top-level scratch dir from rerender).
aplus-content/

# State lock sidecars (transient — fcntl.flock anchors)
marketing/state/*.lock

# Embedding cache (rebuilt cheaply each CI run; would bloat repo)
marketing/state/blog-embeddings.json

# Spotlight orchestrator local run history — accumulates per-machine
marketing/state/spotlight-runs.json

# Case study Phase 1 — local-only files
marketing/scripts/**/*.bak

# Orphaned state dir from the pre-fix path bug (real state lives at marketing/state/)
marketing/scripts/state/

# Spotlight reel — standalone prototype scratch (superseded by marketing/scripts/b2c/reel/)
/spotlight-reel/
/spotlight-reel-*.mp4

# Textstory — standalone prototype scratch (superseded by marketing/scripts/b2c/textstory/)
/textstory/
/textstory-*.mp4

# ops/scorecard — secrets are written at runtime by CI; never commit them
ops/scorecard/service_account.json
ops/scorecard/.env
