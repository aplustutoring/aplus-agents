# aplus_email_agent secrets. Copy to .env for local dev (gitignored).
# In CI these are GitHub Actions secrets, injected via the workflow env: block.

# HubSpot private app token. MUST have scopes:
#   conversations.read, conversations.write, tickets,
#   crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_PRIVATE_APP_TOKEN=

# Teachworks API token (Account > Add-ons > API > Generate API Token)
TEACHWORKS_TOKEN=

# Anthropic API key (classification — Claude Sonnet).
# This is a DEDICATED key for the email agent — a different token than the one
# aplus-marketing-skills uses. Secrets are per-repo, so they stay isolated.
ANTHROPIC_API_KEY=

# Slack bot token (xoxb-...). Scopes: chat:write, im:write, users:read
SLACK_BOT_TOKEN=

# Monday.com API token (writes to L10 Scorecard board 18402267902)
MONDAY_TOKEN=

# Google service account JSON for the dashboard Sheet.
# Local: path to the json file. CI: the full JSON string (GOOGLE_SHEETS_CREDS secret).
GOOGLE_SHEETS_CREDS=

# Set to "true" to log intended actions without writing to HubSpot/Slack/Monday/Sheets.
DRY_RUN=false

# Teachworks IN-PERSON account token (we run two accounts: online + in-person)
TEACHWORKS_TOKEN_INPERSON=
