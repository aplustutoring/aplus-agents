# ops/call_agent — environment variables
# Copy to .env for local runs (never commit .env — it is gitignored repo-wide).
# In GitHub Actions these are wired as repo secrets and injected by the workflow.

# ── JustCall API (key + secret pair; see README for where to generate) ──
JUSTCALL_API_KEY=
JUSTCALL_API_SECRET=

# ── HubSpot (private-app token, Bearer). Either name works — HUBSPOT_API_KEY
#    (ops/scorecard convention, Actions secret) or HUBSPOT_PRIVATE_APP_TOKEN
#    (marketing convention, already in the repo-root .env). ──
HUBSPOT_API_KEY=

# ── Anthropic (call summarization) ──
ANTHROPIC_API_KEY=

# ── Slack digest delivery ──
# Primary: incoming-webhook URL (matches ops/scorecard convention). The channel
# is fixed by the webhook's config.
SLACK_WEBHOOK_URL=
# Optional alternative: a bot token + explicit channel (set slack.channel in
# config.yml). If SLACK_BOT_TOKEN is set it takes precedence over the webhook.
SLACK_BOT_TOKEN=
